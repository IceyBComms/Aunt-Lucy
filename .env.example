# Aunt Lucy — local development environment.
#
# Copy this file to `.env` (which is gitignored) and fill in the values:
#     cp .env.example .env        (macOS/Linux)
#     copy .env.example .env      (Windows cmd)
#
# Then start everything with one command from the repo root:
#     pnpm dev
#
# This runs the API server (http://localhost:3001) and the web app
# (http://localhost:5173) together; the web app proxies /api to the API server.
# Ports/base path for local dev are set by the `dev:local` scripts, so they do
# NOT belong in this file — only the shared values below do.

# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string. Provide your own local or hosted database.
DATABASE_URL=postgres://user:password@localhost:5432/auntlucy

# ─── Optional (features degrade gracefully if unset) ─────────────────────────

# Resend API key — magic-link, claim, invite and pilot emails. Without it,
# email sending is skipped (and logged) rather than failing.
RESEND_API_KEY=

# Admin email — the only organiser allowed to view pilot applications.
ADMIN_EMAIL=

# Public base URL used to build links inside emails. For local dev the web app
# runs at http://localhost:5173.
APP_URL=http://localhost:5173

# Twilio credentials — trusted-helper SMS invites. Without them, SMS is skipped.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Log level for the API server (default: info).
# LOG_LEVEL=debug
