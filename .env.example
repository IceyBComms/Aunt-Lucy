# Aunt Lucy — local development environment.
#
# Copy this file to `.env` (which is gitignored) and fill in the values:
#     cp .env.example .env        (macOS/Linux)
#     copy .env.example .env      (Windows cmd)
#
# Then start everything with one command from the repo root:
#     pnpm dev
#
# This runs the API server (http://localhost:3001) and the web app
# (http://localhost:5173) together; the web app proxies /api to the API server.
# Ports/base path for local dev are set by the `dev:local` scripts, so they do
# NOT belong in this file — only the shared values below do.

# ─── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string. Provide your own local or hosted database.
DATABASE_URL=postgres://user:password@localhost:5432/auntlucy

# ─── Optional (features degrade gracefully if unset) ─────────────────────────

# Resend API key — magic-link, claim, invite and pilot emails.
# For local dev, leave this as a value containing "placeholder": real email
# sending is disabled and magic-link sign-in URLs are printed to the terminal
# console so you can copy them. Set a real key to actually send email.
RESEND_API_KEY=placeholder

# Admin email — the only organiser allowed to view pilot applications.
ADMIN_EMAIL=

# Public base URL used to build links inside emails. For local dev the web app
# runs at http://localhost:5173.
APP_URL=http://localhost:5173

# Twilio credentials — trusted-helper SMS invites. Without them, SMS is skipped.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Stripe — the post-purchase fulfilment webhook. Use TEST-mode keys locally;
# the live payment links take real money. Get the webhook secret by running
# `stripe listen --forward-to localhost:3001/api/stripe/webhook`, which prints a
# whsec_… value for the duration of that session. Without both, the webhook
# returns 503 rather than trusting an unverified request.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Australian GST rate used to itemise tax receipts. Defaults to 0.10 if unset.
TAX_RATE=0.10

# Supplier details printed on the tax receipt.
BUSINESS_LEGAL_NAME=Icebreaker Communications
BUSINESS_ABN=34 327 702 731

# Shared secret for POST /api/internal/dispatch-scheduled, sent by the external
# cron as the x-internal-cron-secret header. Unset = the endpoint is disabled.
INTERNAL_CRON_SECRET=

# Log level for the API server (default: info).
# LOG_LEVEL=debug
